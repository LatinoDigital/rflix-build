<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:startColor="#40b71c1c" android:endColor="#30880e4f" android:angle="135.0" android:type="linear" />
                    <corners android:radius="8.0dip" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1.0dip" android:color="#80b71c1c" />
                    <corners android:radius="8.0dip" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#20b71c1c" android:endColor="#10b71c1c" android:angle="90.0" android:type="linear" />
            <corners android:radius="8.0dip" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="8.0dip" />
        </shape>
    </item>
</selector>