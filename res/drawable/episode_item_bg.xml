<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient android:startColor="#30b71c1c" android:endColor="#20880e4f" android:angle="135.0" android:type="linear" />
                    <corners android:radius="12.0dip" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1.0dip" android:color="#60b71c1c" />
                    <corners android:radius="12.0dip" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#20b71c1c" />
            <corners android:radius="12.0dip" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0cffffff" />
            <corners android:radius="12.0dip" />
            <stroke android:width="1.0dip" android:color="#0affffff" />
        </shape>
    </item>
</selector>