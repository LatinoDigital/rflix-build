<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tivimate_focus_fill" />
            <stroke android:width="1.0dip" android:color="@color/tivimate_focus_stroke" />
            <corners android:radius="@dimen/tivimate_radius_pill" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tivimate_focus_fill" />
            <corners android:radius="@dimen/tivimate_radius_pill" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="@dimen/tivimate_radius_pill" />
        </shape>
    </item>
</selector>